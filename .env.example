# =============================================================================
# TMS — Environment variables
# =============================================================================
# Option A — .env file:  cp .env.example .env  then edit. Use make run-all or run-with-env.sh.
# Option B — ~/.zshrc:  use the same names with export (e.g. export DB_HOST=localhost).
# =============================================================================

# --- PostgreSQL (each service has its own DB; see docker/init-dbs.sql) ---
# Do NOT set SPRING_DATASOURCE_URL — it overrides all services and breaks file/ticket/notification DBs.
DB_HOST=localhost
DB_PORT=5432
DB_USER=tms
DB_PASSWORD=tms

# --- Auth Service: JWT RS256 keys (Base64-encoded PEM) ---
AUTH_JWT_PRIVATE_KEY="LS0tLS1CRUdJTiBQUklWQVRF..."
AUTH_JWT_PUBLIC_KEY="LS0tLS1CRUdJTiBQVUJMS..."

# --- Auth Service: Redis (MFA code storage) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Auth / Notification: Resend (MFA and notification emails) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="TMS <noreply@example.com>"

# --- Kafka (ticket, notification, file services) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- MinIO (file-service) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=tms
MINIO_SECRET_KEY=tms12345
MINIO_BUCKET=tms-files

# --- API Gateway: CORS (Angular app origin) ---
CORS_ALLOWED_ORIGIN=http://localhost:4200
