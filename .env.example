# =============================================================================
# TMS — Environment variables (copy to .env and adjust)
# =============================================================================
# Copy this file to .env:  cp .env.example .env
# Spring Boot reads env vars automatically: SPRING_DATASOURCE_URL → spring.datasource.url
# Source before running:  set -a && source .env && set +a  (or use ./scripts/run-with-env.sh)
# =============================================================================

# --- PostgreSQL (matches docker-compose.yml) ---
POSTGRES_USER=tms
POSTGRES_PASSWORD=tms
POSTGRES_DB=tms

# --- Spring Datasource (each service uses its own DB; override via env if needed) ---
# DBs: tms_auth, tms_tickets, tms_files, tms_notifications (see docs/DEVELOPMENT_PLAN.md)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tms_auth
SPRING_DATASOURCE_USERNAME=tms
SPRING_DATASOURCE_PASSWORD=tms

# --- Redis (auth-service; matches docker-compose) ---
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# --- Kafka (ticket-service, notification-service; matches docker-compose) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- MinIO (file-service; matches docker-compose) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=tms
MINIO_SECRET_KEY=tms12345
MINIO_BUCKET=tms-files

# --- Optional: service-specific DB URLs (set when running that service) ---
# Auth:     SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tms_auth
# Ticket:   SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tms_tickets
# Notify:   SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tms_notifications
# File:     SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tms_files
